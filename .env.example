# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=loan-default-prediction

# Model Configuration
MODEL_PATH=models/model.pkl
MODEL_NAME=loan_default_classifier

# Data Paths
RAW_DATA_PATH=data/raw/cs-training.csv
PROCESSED_DATA_PATH=data/processed/

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# AWS Configuration (for later)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket-name

# Database (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/loan_db
